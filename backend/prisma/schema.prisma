generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  role        String    @default("GUEST") // GUEST, CHEF, MANAGER, ADMIN
  password    String
  clockInTime DateTime? // For Fatigue Monitoring
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Order       Order[]   @relation("GuestOrders")
  ChefOrders  Order[]   @relation("ChefOrders")
  ShiftLogs   ShiftLog[]
}

model Ingredient {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  unit            String   // e.g. "g", "ml", "pcs"
  currentStock    Float    @default(0)
  minimumReorder  Float    @default(0)
  unitCost        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  BillOfMaterial  BillOfMaterial[]
  WasteLog        WasteLog[]
  Reconciliations StockReconciliation[]
}

model MenuItem {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  category     String
  price        Float
  size         String   @default("Normal") // e.g. Small, Medium, Large, Normal
  prepTimeMins Int      @default(15)
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  BillOfMaterial BillOfMaterial[]
  OrderItem      OrderItem[]

  // Make name + size unique to avoid identical items
  @@unique([name, size])
}

model BillOfMaterial {
  id           Int        @id @default(autoincrement())
  menuItemId   Int
  ingredientId Int
  quantity     Float      // amount of ingredient required

  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([menuItemId, ingredientId])
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      Int?        // Optional guest account relation
  chefId      Int?        // Assigned Chef
  tableNumber Int?
  status      String      @default("QUEUED") // QUEUED, IN_PROGRESS, COMPLETED, CANCELLED
  totalAmount Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User?       @relation("GuestOrders", fields: [userId], references: [id])
  chef        User?       @relation("ChefOrders", fields: [chefId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  menuItemId Int
  quantity   Int      @default(1)
  status     String   @default("QUEUED") // QUEUED, IN_PROGRESS, COMPLETED
  
  order      Order    @relation(fields: [orderId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model WasteLog {
  id           Int      @id @default(autoincrement())
  ingredientId Int
  quantity     Float
  reason       String   // e.g. "Spillage", "Burnt", "Spoiled"
  loggedBy     Int?     // User ID of the Chef/Manager who logged it
  createdAt    DateTime @default(now())

  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Alert {
  id           Int      @id @default(autoincrement())
  type         String   // e.g. "LOW_STOCK", "FATIGUE", "WAIT_TIME"
  message      String
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model StockReconciliation {
  id              Int        @id @default(autoincrement())
  ingredientId    Int
  expectedStock   Float
  physicalStock   Float
  discrepancy     Float
  loggedBy        Int?
  createdAt       DateTime   @default(now())
  
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
}

model ShiftLog {
  id           Int        @id @default(autoincrement())
  userId       Int
  clockInTime  DateTime
  clockOutTime DateTime?
  hoursWorked  Float?
  ordersDone   Int        @default(0)
  
  user         User       @relation(fields: [userId], references: [id])
}

